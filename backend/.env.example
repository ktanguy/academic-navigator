# Academic Navigator Backend Configuration
# Copy this file to .env and fill in your values

# ======================
# REQUIRED SETTINGS
# ======================

# Secret key for JWT tokens (change in production!)
SECRET_KEY=your-secret-key-change-this-in-production

# Database URL (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///academic_navigator.db
# For production: DATABASE_URL=postgresql://user:password@host:5432/dbname

# ======================
# EMAIL NOTIFICATIONS
# ======================
# Choose one provider: 'sendgrid', 'gmail_smtp', or 'none'
EMAIL_PROVIDER=none

# Option 1: SendGrid (Recommended for production)
# Sign up at https://sendgrid.com (100 emails/day free)
SENDGRID_API_KEY=your-sendgrid-api-key

# Option 2: Gmail SMTP
# Create an App Password: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# From address for outgoing emails
EMAIL_FROM=noreply@your-domain.com

# ======================
# GOOGLE OAUTH (Optional)
# ======================
# For Google Sign-In and Gmail API integration
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# ======================
# AI CLASSIFICATION
# ======================
# Set to 'true' to use DistilBERT AI model (requires more memory)
# Set to 'false' to use keyword-based classification (faster, less memory)
USE_AI_CLASSIFIER=false

# ======================
# SERVER SETTINGS
# ======================
PORT=5001
FLASK_ENV=development
FLASK_DEBUG=true
